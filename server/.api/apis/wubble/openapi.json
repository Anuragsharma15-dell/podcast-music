{
  "openapi": "3.0.0",
  "info": {
    "title": "WubbleTech API",
    "description": "API Gateway for WubbleTech's multimodal generation APIs",
    "version": "1.0.0"
  },
  "x-google-backend": {
    "address": "https://wubble-api-196881108127.asia-southeast1.run.app"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check endpoint",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "Service is healthy"
          },
          "503": {
            "description": "Service unavailable"
          }
        }
      }
    },
    "/docs": {
      "get": {
        "summary": "API documentation",
        "operationId": "apiDocs",
        "responses": {
          "200": {
            "description": "API documentation page"
          },
          "404": {
            "description": "Documentation not found"
          }
        }
      }
    },
    "/swagger-ui-bundle.js": {
      "get": {
        "summary": "Swagger UI Bundle JS",
        "operationId": "swaggerUIBundle",
        "responses": {
          "200": {
            "description": "Swagger UI JavaScript bundle"
          }
        }
      }
    },
    "/swagger-ui-standalone-preset.js": {
      "get": {
        "summary": "Swagger UI Standalone Preset JS",
        "operationId": "swaggerUIPreset",
        "responses": {
          "200": {
            "description": "Swagger UI Standalone Preset JavaScript"
          }
        }
      }
    },
    "/swagger-ui-init.js": {
      "get": {
        "summary": "Swagger UI Init JS",
        "operationId": "swaggerUIInit",
        "responses": {
          "200": {
            "description": "Swagger UI Init JavaScript"
          }
        }
      }
    },
    "/swagger-ui.css": {
      "get": {
        "summary": "Swagger UI CSS",
        "operationId": "swaggerUICSS",
        "responses": {
          "200": {
            "description": "Swagger UI CSS styles"
          }
        }
      }
    },
    "/api/user": {
      "post": {
        "summary": "Create a new user",
        "operationId": "createUser",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "plan": {
                    "type": "string",
                    "enum": [
                      "free",
                      "payg",
                      "fixed"
                    ],
                    "default": "free"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "User created successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/user/{userId}": {
      "post": {
        "summary": "Delete a user",
        "operationId": "deleteUser",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/v1/apikeys": {
      "post": {
        "summary": "Create a new API key",
        "operationId": "createApiKey",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Existing API key deactivated"
          },
          "201": {
            "description": "API key created successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": []
      },
      "get": {
        "summary": "List API keys",
        "operationId": "listApiKeys",
        "responses": {
          "200": {
            "description": "List of API keys retrieved successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/v1/apikeys/{keyId}": {
      "delete": {
        "summary": "Revoke an API key",
        "operationId": "revokeApiKey",
        "parameters": [
          {
            "name": "keyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "API key revoked successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "API key not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/v1/chat": {
      "post": {
        "summary": "Chat endpoint for multimodal requests",
        "operationId": "chatMultimodal",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "prompt"
                ],
                "properties": {
                  "project_id": {
                    "type": "string"
                  },
                  "prompt": {
                    "type": "string",
                    "default": ""
                  },
                  "images": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "audios": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "videos": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "documents": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Chat response generated successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "402": {
            "description": "Insufficient credits"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/v1/polling/{requestId}": {
      "get": {
        "summary": "Poll for request completion status",
        "operationId": "pollRequest",
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request completed successfully"
          },
          "202": {
            "description": "Request still processing"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Request not found"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/v1/request/{requestId}/status": {
      "get": {
        "summary": "Check request status",
        "operationId": "checkRequestStatus",
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request status retrieved successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Request not found"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/v1/upload": {
      "post": {
        "summary": "Upload a single media file",
        "operationId": "uploadFile",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "File uploaded successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "402": {
            "description": "Insufficient credits"
          },
          "413": {
            "description": "File too large"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/v1/upload/delete/{fileName}": {
      "delete": {
        "summary": "Delete a file from storage",
        "operationId": "deleteFile",
        "parameters": [
          {
            "name": "fileName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File deleted successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - can only delete own files"
          },
          "404": {
            "description": "File not found"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/v1/credits": {
      "get": {
        "description": "",
        "operationId": "get_apiv1credits",
        "responses": {
          "200": {
            "description": ""
          }
        },
        "parameters": [],
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "x-google-iam": {
    "serviceAccount": "wubble-api@wubble2024.iam.gserviceaccount.com"
  },
  "servers": [
    {
      "url": "https://api.wubble.ai/"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}